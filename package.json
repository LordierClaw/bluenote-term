{
  "name": "bluenote",
  "version": "0.4.0",
  "description": "Terminal-native, local-first Markdown notes.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/term"
  ],

  "keywords": [
    "markdown",
    "notes",
    "terminal",
    "cli",
    "tui",
    "local-first"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "bun run ./bin/bn.ts",
    "dev:tui": "bun run ./packages/term/src/tui/app.ts",
    "check:env": "bun run ./scripts/check-env.ts",
    "smoke:opentui": "bun run ./scripts/smoke-opentui.ts",
    "smoke:cli": "bun run ./scripts/smoke-cli.ts",
    "build:release": "bun run ./scripts/package-release.ts",
    "package:release": "bun run ./scripts/package-release.ts",
    "lint": "biome lint --diagnostic-level=error .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e",
    "check": "bun run lint && bun run typecheck && bun run test && bun run smoke:opentui && bun run smoke:cli"
  },
  "dependencies": {
    "@lordierclaw/bluenote-core": "git+https://github.com/LordierClaw/bluenote-core.git#920f5c1030604a5be98d8d70d87d06ec0a57fb28",
    "@opentui/core": "0.2.14",
    "clipboardy": "5.3.1",
    "sql.js": "1.10.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "typescript": "6.0.3"
  }
}
