{
  "name": "bluenote",
  "version": "0.1.0",
  "description": "Terminal-native, local-first Markdown notes.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "bn": "./bin/bn.ts",
    "bluenote": "./bin/bn.ts"
  },
  "keywords": [
    "markdown",
    "notes",
    "terminal",
    "cli",
    "tui",
    "local-first"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "bun run ./bin/bn.ts",
    "dev:tui": "bun run ./src/tui/app.ts",
    "check:env": "bun run ./scripts/check-env.ts",
    "smoke:opentui": "bun run ./scripts/smoke-opentui.ts",
    "smoke:opentui:interactive": "bun run ./scripts/smoke-opentui-interactive.ts",
    "qa:visual:tui": "bun run ./scripts/visual-tui-qa.ts",
    "smoke:cli": "bun run ./scripts/smoke-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e",
    "check": "bun run typecheck && bun run test && bun run smoke:opentui && bun run smoke:opentui:interactive && bun run smoke:cli"
  },
  "dependencies": {
    "@opentui/core": "0.3.0",
    "clipboardy": "5.3.1",
    "js-yaml": "4.1.1",
    "minisearch": "7.2.0",
    "sql.js": "1.14.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.18",
    "@types/node": "20.19.0",
    "typescript": "5.8.3"
  }
}
