{
  "name": "bluenote",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal-native, local-first note tool scaffold for Bun/OpenTUI.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "bn": "./bin/bn.ts",
    "bluenote": "./bin/bn.ts"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "bun run ./bin/bn.ts",
    "dev:tui": "bun run ./src/tui/app.ts",
    "check:env": "bun run ./scripts/check-env.ts",
    "smoke:opentui": "bun run ./scripts/smoke-opentui.ts",
    "smoke:cli": "bun run ./bin/bn.ts --help",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun run test && bun run smoke:opentui && bun run smoke:cli"
  },
  "dependencies": {
    "@opentui/core": "0.2.14",
    "js-yaml": "4.1.0",
    "minisearch": "6.3.0",
    "sql.js": "1.10.3"
  },
  "devDependencies": {
    "@types/bun": "1.2.18",
    "@types/node": "20.19.0",
    "typescript": "5.8.3"
  }
}
