{
  "name": "@lordierclaw/bluenote-term",
  "version": "0.4.14",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LordierClaw/bluenote-term"
  },
  "type": "module",
  "files": [
    "bin/bluenote-term.js",
    "dist",
    "src/command.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/command.d.ts",
      "import": "./dist/command.js"
    },
    "./command": {
      "types": "./src/command.d.ts",
      "import": "./dist/command.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "bluenote-term": "./bin/bluenote-term.js"
  },
  "scripts": {
    "build:package-runtime": "bun ../../scripts/build-package-runtime.ts",
    "prepack": "bun run build:package-runtime"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@lordierclaw/bluenote-core": "latest",
    "@opentui/core": "0.4.3",
    "clipboardy": "5.3.1"
  }
}
